{
  "name": "novel-knowledge-mcp-server",
  "version": "1.0.0",
  "description": "MCP server for novel writing knowledge base management",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "novel-knowledge-mcp-server": "dist/index.js"
  },
  "scripts": {
    "build": "esbuild src/index.ts --bundle --platform=node --format=esm --outfile=dist/index.js --external:@modelcontextprotocol/sdk --external:express --external:zod",
    "watch": "esbuild src/index.ts --bundle --platform=node --format=esm --outfile=dist/index.js --external:@modelcontextprotocol/sdk --external:express --external:zod --watch",
    "start": "node dist/index.js",
    "dev": "npm run build && node dist/index.js"
  },
  "keywords": [
    "mcp",
    "novel",
    "writing",
    "knowledge-base"
  ],
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.4",
    "express": "^4.18.2",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^20.10.0",
    "esbuild": "^0.27.3",
    "typescript": "^5.3.3"
  }
}
